# Copy this file to .env and fill in your values
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=http://your-api-gateway:3000/v1
LLM_MODEL=claude-opus-4-5

# Vision LLM (optional)
VISION_LLM_MODEL=gemini-2.5-flash
VISION_LLM_BASE_URL=http://your-api-gateway:3000/v1

# ── Cloudflare Bypass (Camoufox) ──────────────────────────────────────────────
# When using docker-compose, BROWSER_WS_URL is set automatically.
# For local dev without docker-compose, point to a running Camoufox server:
# BROWSER_WS_URL=ws://localhost:1234/ws

# Optional: residential proxy for production-scale crawling
# Without this, Camoufox still bypasses CF via fingerprint spoofing alone.
# With this, IP reputation is also clean (recommended for high-volume scraping).
# PROXY_URL=http://username:password@residential-proxy-host:8080

# ── Legacy browser modes (lower priority than BROWSER_WS_URL) ────────────────
# CDP remote Chrome (experimental, requires manual Chrome setup)
# BROWSER_CDP_URL=http://host.docker.internal:9222
# Playwright storage state (cookie auth — ineffective against CF)
# BROWSER_STORAGE_STATE=/app/states/auth_state.json
